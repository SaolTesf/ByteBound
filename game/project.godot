; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="ByteBound"
run/main_scene="res://ui/main-menu/main_menu_control_node.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://Assets/icon.svg"

[autoload]

SignalHub="*res://autoloads/signal_hub.gd"
SceneManager="*res://autoloads/scene_manager.gd"
Debug="*res://autoloads/debug.gd"
AudioController="*res://autoloads/audio_controller.tscn"
AudioPool="*res://addons/audio-pool/autoloads/audio_pool.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"

[dotnet]

project/assembly_name="ByteBound"

[file_customization]

folder_colors={
"res://Assets/": "orange",
"res://Assets/Objects/Barriers/BlueBeam/": "blue",
"res://Assets/Objects/Barriers/GreenBeam/": "green",
"res://Assets/Objects/Barriers/RedBeam/": "red",
"res://Assets/Objects/Buttons/BluePedistal/": "blue",
"res://Assets/Objects/Buttons/BluePressurePlate/": "blue",
"res://Assets/Objects/Buttons/GreenPedistal/": "green",
"res://Assets/Objects/Buttons/GreenPressurePlate/": "green",
"res://Assets/Objects/Buttons/RedPedistal/": "red",
"res://Assets/Objects/Buttons/RedPressurePlate/": "red",
"res://addons/": "red",
"res://autoloads/": "yellow",
"res://components/": "green",
"res://custom-resources/": "teal",
"res://entites/": "blue",
"res://entites/objects/buttons/pedestals/blue-pedestal/": "blue",
"res://entites/objects/buttons/pedestals/green-pedestal/": "green",
"res://entites/objects/buttons/pedestals/red-pedestal/": "red",
"res://entites/objects/buttons/pressure-plates/blue-pressure-plate/": "blue",
"res://entites/objects/buttons/pressure-plates/green-pressure-plate/": "green",
"res://entites/objects/buttons/pressure-plates/red-pressure-plate/": "red",
"res://entites/objects/hazards/lazers/blue-lazer/": "blue",
"res://entites/objects/hazards/lazers/green-laser/": "green",
"res://entites/objects/hazards/lazers/red-laser/": "red",
"res://scenes/": "purple",
"res://ui/": "pink"
}

[global_group]

Enemy="All Enemy units"
Player="Player character"
Throwable="Objects that can be picked up and thrown"

[input]

dash={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194325,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
crouch={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194326,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
interact={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":69,"key_label":0,"unicode":101,"location":0,"echo":false,"script":null)
]
}
throw={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":84,"key_label":0,"unicode":84,"location":0,"echo":false,"script":null)
]
}

[layer_names]

2d_physics/layer_1="Terrain"
2d_physics/layer_2="Player"
2d_physics/layer_3="Enemies"
2d_physics/layer_4="Hazards"
2d_physics/layer_5="Buttons"
2d_physics/layer_6="Movables"
2d_physics/layer_7="Throwables"
2d_physics/layer_8="Collectables"

[rendering]

textures/canvas_textures/default_texture_filter=0
textures/vram_compression/import_s3tc_bptc=true
textures/vram_compression/import_etc2_astc=true
2d/snap/snap_2d_transforms_to_pixel=true
